# ============================================================================
# Model Provider Selection
# ============================================================================
# Which LLM to use: "gemini", "anthropic", or "openai_compatible"
MODEL_PROVIDER=gemini

# ============================================================================
# Gemini Configuration (Google)
# ============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Alternative key name
# GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override default model
# GEMINI_MODEL=gemini-2.5-computer-use-preview-10-2025

# ============================================================================
# Anthropic Configuration (Claude)
# ============================================================================
# Get your API key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Override default model
# ANTHROPIC_MODEL=claude-haiku-4-5

# ============================================================================
# OpenAI-Compatible Configuration (Local / Mesh Router)
# ============================================================================
# Use this if you want to drive the agent with a local vision model behind an
# OpenAI-compatible `/v1/chat/completions` endpoint (e.g., Mesh-Router).
#
# MODEL_PROVIDER=openai_compatible
# OPENAI_BASE_URL=http://localhost:4010/v1
# OPENAI_API_KEY=optional_if_your_router_requires_it
# OPENAI_MODEL=your_vision_model_name_here
#
# Optional: strict JSON mode (if your server supports it)
# OPENAI_RESPONSE_FORMAT=json_object
#
# Optional: tune local VLM latency/cost.
# OPENAI_TIMEOUT_S=300
# OPENAI_MAX_TOKENS=300
# OPENAI_SCREENSHOT_MAX_WIDTH=512

# ============================================================================
# MCP Server Configuration
# ============================================================================
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ============================================================================
# VNC Configuration (for local testing)
# ============================================================================
VNC_SERVER=vnc-desktop::5901
VNC_PASSWORD=vncpassword
